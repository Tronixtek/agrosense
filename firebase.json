{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".gitignore",
      "**/.*",
      "**/node_modules/**",
      "*.exe",
      "**/*.exe",
      "*.msi",
      "**/*.msi",
      "*.bat",
      "**/*.bat",
      "*.cmd",
      "**/*.cmd",
      "*.ps1",
      "**/*.ps1",
      "*.docx",
      "*.zip",
      "skills-lock.json",
      "firebase_config.js"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
